<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cpnvisualsystem.mapper.CarriageInfoMapper">
    <resultMap id="BaseResultMap" type="org.cpnvisualsystem.entity.CarriageInfo">
        <id column="id" property="id" />
        <result column="cluster_id" property="clusterId" />
        <result column="train_id" property="trainId" />
        <result column="position" property="position" />
        <result column="device_count" property="deviceCount" />
    </resultMap>

    <sql id="Base_Column_List">
        id, cluster_id, train_id, position, device_count
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM carriage_info
        WHERE id = #{id}
    </select>
</mapper>
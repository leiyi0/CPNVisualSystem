<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cpnvisualsystem.mapper.ComputeNodesMapper">
    <select id="selectById" resultType="org.cpnvisualsystem.entity.ComputeNodes">
        SELECT * FROM compute_nodes WHERE id = #{id}
    </select>

    <select id="selectDevicesByCarriageId" resultType="org.cpnvisualsystem.entity.ComputeNodes">
        SELECT n.* FROM compute_nodes n
                            JOIN compute_power_tag t ON n.ip = t.ip
        WHERE t.carriage = #{carriageId}
    </select>
</mapper>